@model CustOrder
@{ ViewData["Title"] = "Booking Details"; ViewData["Subtitle"] = Model.BookingId; }

<div class="panel-card panel-card-padded mb-4">
    <div class="d-flex flex-wrap gap-2 align-items-center mb-3">
        <span class="panel-badge panel-badge-info">@Model.OrderStatus</span>
        <span class="panel-badge @(Model.PaymentStatus == "Paid" ? "panel-badge-success" : "panel-badge-warning")">@Model.PaymentStatus</span>
    </div>
    <partial name="_StatusTimeline" model="Model" />
</div>

<div class="row g-4">
    <div class="col-lg-6">
        <div class="panel-card">
            <div class="panel-card-header"><h6><i class="bi bi-calendar-event"></i> Event Details</h6></div>
            <div class="panel-card-body-padded">
                <table class="table table-borderless table-sm mb-0">
                    <tr><td class="text-muted">Caterer</td><td class="text-end"><strong>@Model.Caterer?.BusinessName</strong></td></tr>
                    <tr><td class="text-muted">Event Type</td><td class="text-end">@Model.EventType</td></tr>
                    <tr><td class="text-muted">Event Date</td><td class="text-end">@Model.EventDate.ToString("dddd, dd MMM yyyy")</td></tr>
                    <tr><td class="text-muted">Venue</td><td class="text-end">@Model.EventVenue</td></tr>
                    <tr><td class="text-muted">Guests</td><td class="text-end">@Model.GuestCount</td></tr>
                    <tr><td class="text-muted">Booked On</td><td class="text-end">@Model.OrderDate.ToString("dd MMM yyyy")</td></tr>
                    @if (Model.PaymentStatus == "Paid" && !string.IsNullOrEmpty(Model.PaymentMethod))
                    {
                        <tr><td class="text-muted">Payment</td><td class="text-end"><span class="panel-badge panel-badge-success">@Model.PaymentMethod</span> @Model.PaymentReference</td></tr>
                    }
                    @if (!string.IsNullOrEmpty(Model.SpecialInstructions))
                    {
                        <tr><td class="text-muted">Notes</td><td class="text-end">@Model.SpecialInstructions</td></tr>
                    }
                </table>
            </div>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="panel-card">
            <div class="panel-card-header"><h6><i class="bi bi-list-ul"></i> Order Items</h6></div>
            <div class="panel-table-wrap">
                <table class="table panel-table mb-0">
                    <thead><tr><th>Item</th><th>Qty</th><th>Price</th><th class="text-end">Total</th></tr></thead>
                    <tbody>
                        @foreach (var item in Model.OrderItems)
                        {
                            <tr>
                                <td>@item.MenuItem?.ItemName</td>
                                <td>@item.Quantity</td>
                                <td>Rs. @item.UnitPrice</td>
                                <td class="text-end">Rs. @item.LineTotal.ToString("N0")</td>
                            </tr>
                        }
                    </tbody>
                    <tfoot>
                        <tr><th colspan="3" class="text-end border-0">Total</th><th class="text-end border-0">Rs. @Model.TotalAmount.ToString("N0")</th></tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>
</div>

@if (Model.Invoice != null)
{
    <div class="panel-card mt-4">
        <div class="panel-card-header"><h6><i class="bi bi-receipt"></i> Invoice @Model.Invoice.InvoiceNumber</h6></div>
        <div class="panel-card-body-padded">
            <p class="text-muted small">Date: @Model.Invoice.InvoiceDate.ToString("dd MMM yyyy")</p>
            <div class="panel-table-wrap">
                <table class="table panel-table mb-0">
                    @foreach (var item in Model.Invoice.InvoiceItems)
                    {
                        <tr>
                            <td>@item.ItemName</td>
                            <td>@item.Quantity</td>
                            <td>Rs. @item.UnitPrice</td>
                            <td class="text-end">Rs. @item.LineTotal.ToString("N0")</td>
                        </tr>
                    }
                </table>
            </div>
            <p class="mt-3 mb-0"><strong>Grand Total: Rs. @Model.Invoice.GrandTotal.ToString("N0")</strong></p>
        </div>
    </div>
}

<div class="mt-4 d-flex flex-wrap gap-2">
    @if (Model.PaymentStatus == "Pending")
    {
        <a asp-action="Payment" asp-route-orderId="@Model.OrderId" class="panel-btn panel-btn-accent px-4 py-2">Complete Payment</a>
    }
    @if (Model.OrderStatus != "Cancelled" && Model.OrderStatus != "Completed")
    {
        <form asp-action="CancelBooking" method="post" onsubmit="return confirm('Cancel this booking?');">
            <input type="hidden" name="id" value="@Model.OrderId" />
            <button type="submit" class="panel-btn panel-btn-delete px-4 py-2">Cancel Booking</button>
        </form>
    }
    <a asp-action="SendMessage" asp-route-receiverId="@Model.CatererId" asp-route-receiverType="Caterer" asp-route-receiverName="@Model.Caterer?.BusinessName" class="panel-btn panel-btn-outline px-4 py-2">Message Caterer</a>
    <a asp-action="MyBookings" class="panel-btn panel-btn-view px-4 py-2"><i class="bi bi-arrow-left"></i> Back</a>
</div>

@if (Model.CancellationCharge.HasValue)
{
    <div class="alert alert-warning mt-3">Cancellation charge: Rs. @Model.CancellationCharge.Value.ToString("N0")</div>
}
