@model IEnumerable<Caterer>
@{ ViewData["Title"] = "Caterers"; ViewData["Subtitle"] = $"{Model.Count()} catering businesses"; }
<div class="admin-card">
    <div class="admin-card-header">
        <h6><i class="bi bi-shop"></i> Caterer List</h6>
        <span class="admin-badge admin-badge-success">@Model.Count(c => c.IsActive) Active</span>
    </div>
    <div class="admin-card-body">
        <div class="admin-table-wrap">
            <table class="table admin-table mb-0">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Business</th>
                        <th>City</th>
                        <th>Area</th>
                        <th>Food</th>
                        <th>Rating</th>
                        <th>Status</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in Model)
                    {
                        <tr>
                            <td><span class="text-muted">#@c.CatererId</span></td>
                            <td><strong>@c.BusinessName</strong></td>
                            <td>@c.City</td>
                            <td>@(string.IsNullOrEmpty(c.Area) ? "—" : c.Area)</td>
                            <td><span class="admin-badge admin-badge-secondary">@c.FoodType</span></td>
                            <td><i class="bi bi-star-fill text-warning"></i> @c.Rating</td>
                            <td>
                                <span class="admin-badge @(c.IsActive ? "admin-badge-success" : "admin-badge-secondary")">
                                    @(c.IsActive ? "Active" : "Inactive")
                                </span>
                            </td>
                            <td>
                                <div class="admin-actions justify-content-end">
                                    <form asp-action="ToggleCaterer" method="post" class="d-inline">
                                        <input type="hidden" name="id" value="@c.CatererId" />
                                        <button type="submit" class="admin-btn admin-btn-toggle"><i class="bi bi-toggle-on"></i> Toggle</button>
                                    </form>
                                    <form asp-action="DeleteCaterer" method="post" class="d-inline" onsubmit="return confirm('Delete this caterer?');">
                                        <input type="hidden" name="id" value="@c.CatererId" />
                                        <button type="submit" class="admin-btn admin-btn-delete"><i class="bi bi-trash"></i></button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
