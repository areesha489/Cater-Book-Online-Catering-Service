@model IEnumerable<CustOrder>
@{ ViewData["Title"] = "Bookings"; ViewData["Subtitle"] = $"{Model.Count()} total bookings"; }
<div class="admin-card">
    <div class="admin-card-header">
        <h6><i class="bi bi-calendar-check-fill"></i> All Bookings</h6>
        <span class="admin-badge admin-badge-warning">@Model.Count(o => o.PaymentStatus == "Pending") Pending Payment</span>
    </div>
    <div class="admin-card-body">
        <div class="admin-table-wrap">
            <table class="table admin-table mb-0">
                <thead>
                    <tr>
                        <th>Booking ID</th>
                        <th>Customer</th>
                        <th>Caterer</th>
                        <th>Event</th>
                        <th>Date</th>
                        <th>Guests</th>
                        <th>Payment</th>
                        <th>Method</th>
                        <th>Status</th>
                        <th class="text-end">Amount</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var o in Model)
                    {
                        var statusClass = o.OrderStatus switch {
                            "Completed" => "admin-badge-success",
                            "Cancelled" => "admin-badge-danger",
                            "Confirmed" => "admin-badge-info",
                            "In Progress" => "admin-badge-purple",
                            _ => "admin-badge-warning"
                        };
                        var payClass = o.PaymentMethod switch {
                            "Easypaisa" => "admin-badge-easypaisa",
                            "JazzCash" => "admin-badge-jazzcash",
                            "Bank Account" => "admin-badge-bank",
                            _ => "admin-badge-secondary"
                        };
                        <tr>
                            <td><code>@o.BookingId</code></td>
                            <td><strong>@o.Customer?.FullName</strong></td>
                            <td>@o.Caterer?.BusinessName</td>
                            <td>@o.EventType</td>
                            <td>@o.EventDate.ToString("dd MMM yyyy")</td>
                            <td>@o.GuestCount</td>
                            <td>
                                <span class="admin-badge @(o.PaymentStatus == "Paid" ? "admin-badge-success" : "admin-badge-warning")">
                                    @o.PaymentStatus
                                </span>
                            </td>
                            <td>
                                @if (string.IsNullOrEmpty(o.PaymentMethod))
                                { <span class="text-muted">—</span> }
                                else
                                { <span class="admin-badge @payClass">@o.PaymentMethod</span> }
                            </td>
                            <td><span class="admin-badge @statusClass">@o.OrderStatus</span></td>
                            <td class="text-end"><strong>Rs. @o.TotalAmount.ToString("N0")</strong></td>
                            <td>
                                <div class="admin-actions">
                                    <a asp-action="BookingDetails" asp-route-id="@o.OrderId" class="admin-btn admin-btn-view"><i class="bi bi-eye"></i></a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
