@{ ViewData["Title"] = "About Us"; ViewData["Subtitle"] = "Connecting customers with the best caterers across Pakistan"; }

<partial name="_PageHeader" />

<div class="container pb-5">
    <div class="row g-4 align-items-center mb-5 reveal">
        <div class="col-lg-6">
            <img src="https://images.unsplash.com/photo-1559339352-11d035aa65de?w=700&q=80" alt="Catering service" class="img-fluid rounded-4 shadow" loading="lazy" />
        </div>
        <div class="col-lg-6">
            <span class="section-tag">Our Story</span>
            <h2 class="section-title">One-Stop Catering Solution</h2>
            <p class="text-muted">CaterBook is Pakistan's web-based platform that connects customers and caterers in one place — weddings, birthdays, corporate meetings, and college functions.</p>
            <p class="text-muted">No more visiting caterers physically. Search, compare menus, book online, pay securely, and track your event — all from your browser.</p>
        </div>
    </div>

    <div class="row g-4 reveal">
        <div class="col-md-4">
            <div class="feature-card">
                <div class="feature-icon-wrap"><i class="bi bi-people"></i></div>
                <h5 class="fw-bold">For Customers</h5>
                <p class="text-muted small mb-0">Search, book, pay, manage bookings, favorites & messaging.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="feature-card">
                <div class="feature-icon-wrap"><i class="bi bi-shop"></i></div>
                <h5 class="fw-bold">For Caterers</h5>
                <p class="text-muted small mb-0">Manage menus, bookings, staff, invoices & suppliers.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="feature-card">
                <div class="feature-icon-wrap"><i class="bi bi-shield-check"></i></div>
                <h5 class="fw-bold">Business Rules</h5>
                <p class="text-muted small mb-0">7 days advance booking · Min 50 guests · Flexible cancellation.</p>
            </div>
        </div>
    </div>
</div>
