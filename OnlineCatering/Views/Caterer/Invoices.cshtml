@model IEnumerable<CustomerInvoice>
@{ ViewData["Title"] = "Invoices"; ViewData["Subtitle"] = $"{Model.Count()} invoice(s)"; }

<div class="panel-card">
    <div class="panel-card-header">
        <h6><i class="bi bi-receipt"></i> Customer Invoices</h6>
    </div>
    <div class="panel-table-wrap">
        <table class="table panel-table mb-0">
            <thead>
                <tr>
                    <th>Invoice #</th>
                    <th>Booking</th>
                    <th>Customer</th>
                    <th>Date</th>
                    <th>Amount</th>
                    <th>Status</th>
                    <th class="text-end">Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var inv in Model)
                {
                    <tr>
                        <td><code>@inv.InvoiceNumber</code></td>
                        <td>@inv.Order?.BookingId</td>
                        <td>@inv.Order?.Customer?.FullName</td>
                        <td>@inv.InvoiceDate.ToString("dd MMM yyyy")</td>
                        <td><strong>Rs. @inv.GrandTotal.ToString("N0")</strong></td>
                        <td><span class="panel-badge panel-badge-info">@inv.Status</span></td>
                        <td class="text-end"><a asp-action="InvoiceDetails" asp-route-id="@inv.InvoiceId" class="panel-btn panel-btn-view">View</a></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
