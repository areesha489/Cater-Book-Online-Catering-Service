@model Menu
@{ ViewData["Title"] = "Edit Menu Item"; }

<div class="container py-5">
    <div class="card form-card p-4">
        <h4>Edit Menu Item</h4>
        <form asp-action="EditMenuItem" method="post">
            <input type="hidden" asp-for="MenuId" />
            <input type="hidden" asp-for="CategoryId" />
            <div class="mb-3">
                <label asp-for="ItemName" class="form-label"></label>
                <input asp-for="ItemName" class="form-control" />
            </div>
            <div class="mb-3">
                <label asp-for="Description" class="form-label"></label>
                <textarea asp-for="Description" class="form-control" rows="2"></textarea>
            </div>
            <div class="mb-3">
                <label asp-for="PricePerPlate" class="form-label"></label>
                <input asp-for="PricePerPlate" class="form-control" type="number" step="0.01" />
            </div>
            <div class="form-check mb-3">
                <input asp-for="IsVeg" class="form-check-input" />
                <label asp-for="IsVeg" class="form-check-label">Vegetarian</label>
            </div>
            <div class="form-check mb-3">
                <input asp-for="IsAvailable" class="form-check-input" />
                <label asp-for="IsAvailable" class="form-check-label">Available</label>
            </div>
            <button type="submit" class="btn btn-accent">Update</button>
            <a asp-action="MenuCategories" class="btn btn-secondary">Cancel</a>
        </form>
    </div>
</div>
