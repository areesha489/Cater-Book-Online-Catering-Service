@model IEnumerable<CustOrder>
@{ ViewData["Title"] = "Bookings"; ViewData["Subtitle"] = $"{Model.Count()} customer booking(s)"; }

<div class="panel-card">
    <div class="panel-card-header">
        <h6><i class="bi bi-calendar-check-fill"></i> Customer Bookings</h6>
    </div>
    <div class="panel-table-wrap">
        <table class="table panel-table mb-0">
            <thead>
                <tr>
                    <th>Booking ID</th>
                    <th>Customer</th>
                    <th>Event</th>
                    <th>Date</th>
                    <th>Guests</th>
                    <th>Amount</th>
                    <th>Payment</th>
                    <th>Status</th>
                    <th class="text-end">Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var order in Model)
                {
                    <tr>
                        <td><code>@order.BookingId</code></td>
                        <td><strong>@order.Customer?.FullName</strong></td>
                        <td>@order.EventType</td>
                        <td>@order.EventDate.ToString("dd MMM yyyy")</td>
                        <td>@order.GuestCount</td>
                        <td>Rs. @order.TotalAmount.ToString("N0")</td>
                        <td><span class="panel-badge @(order.PaymentStatus == "Paid" ? "panel-badge-success" : "panel-badge-warning")">@order.PaymentStatus</span></td>
                        <td><span class="panel-badge panel-badge-info">@order.OrderStatus</span></td>
                        <td class="text-end"><a asp-action="BookingDetails" asp-route-id="@order.OrderId" class="panel-btn panel-btn-view">Manage</a></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
