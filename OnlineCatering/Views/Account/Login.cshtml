@model LoginViewModel
@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "Login";
    ViewData["AuthTitle"] = "Welcome Back";
    ViewData["AuthSubtitle"] = "Sign in to your CaterBook account";
}

<form asp-action="Login" method="post" novalidate>
    <div asp-validation-summary="ModelOnly" class="auth-error-summary"></div>
    <div class="mb-3">
        <label asp-for="UserType" class="form-label"></label>
        <select asp-for="UserType" class="form-select auth-input">
            <option value="Customer">Customer</option>
            <option value="Caterer">Caterer</option>
            <option value="Admin">Admin</option>
        </select>
    </div>
    <div class="mb-3">
        <label asp-for="Username" class="form-label"></label>
        <input asp-for="Username" class="form-control auth-input" placeholder="Enter username" autocomplete="username" />
        <span asp-validation-for="Username" class="auth-field-error"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Password" class="form-label"></label>
        <input asp-for="Password" class="form-control auth-input" placeholder="Enter password" autocomplete="current-password" />
        <span asp-validation-for="Password" class="auth-field-error"></span>
    </div>
    <button type="submit" class="btn-glow w-100 justify-content-center mb-3"><i class="bi bi-box-arrow-in-right"></i> Login</button>
</form>

<div class="auth-links">
    <a asp-action="ForgotPassword">Forgot Password?</a>
    <a asp-action="ResetUsername">Reset Username</a>
</div>

<hr class="auth-divider" />

<p class="text-center auth-muted small mb-2">Don't have an account?</p>
<div class="d-flex gap-2 mb-3">
    <a asp-action="RegisterCustomer" class="btn-glass btn-sm w-50 justify-content-center">Customer</a>
    <a asp-action="RegisterCaterer" class="btn-glass btn-sm w-50 justify-content-center">Caterer</a>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
