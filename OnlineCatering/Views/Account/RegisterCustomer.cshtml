@model CustomerRegisterViewModel
@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "Customer Registration";
    ViewData["AuthTitle"] = "Register as Customer";
    ViewData["AuthSubtitle"] = "Create your account to book caterers online";
    var cities = ViewBag.Cities as string[] ?? OnlineCatering.Services.AreaData.AllCities;
}

<form asp-action="RegisterCustomer" method="post" novalidate>
    <div asp-validation-summary="ModelOnly" class="auth-error-summary"></div>
    <div class="mb-3">
        <label asp-for="FullName" class="form-label"></label>
        <input asp-for="FullName" class="form-control auth-input" placeholder="Your full name" />
        <span asp-validation-for="FullName" class="auth-field-error"></span>
    </div>
    <div class="row g-3">
        <div class="col-md-6">
            <label asp-for="Email" class="form-label"></label>
            <input asp-for="Email" class="form-control auth-input" placeholder="email@example.com" />
            <span asp-validation-for="Email" class="auth-field-error"></span>
        </div>
        <div class="col-md-6">
            <label asp-for="Phone" class="form-label"></label>
            <input asp-for="Phone" class="form-control auth-input" placeholder="03XX XXXXXXX" />
            <span asp-validation-for="Phone" class="auth-field-error"></span>
        </div>
    </div>
    <div class="mb-3 mt-3">
        <label asp-for="Address" class="form-label"></label>
        <input asp-for="Address" class="form-control auth-input" placeholder="Street address" />
    </div>
    <div class="mb-3">
        <label asp-for="City" class="form-label"></label>
        <select asp-for="City" class="form-select auth-input">
            <option value="">Select City</option>
            @foreach (var city in cities)
            {
                <option value="@city">@city</option>
            }
        </select>
        <span asp-validation-for="City" class="auth-field-error"></span>
    </div>
    <hr class="auth-divider" />
    <div class="mb-3">
        <label asp-for="Username" class="form-label"></label>
        <input asp-for="Username" class="form-control auth-input" placeholder="Choose a username" />
        <span asp-validation-for="Username" class="auth-field-error"></span>
    </div>
    <div class="row g-3">
        <div class="col-md-6">
            <label asp-for="Password" class="form-label"></label>
            <input asp-for="Password" class="form-control auth-input" placeholder="Min. 6 characters" />
            <span asp-validation-for="Password" class="auth-field-error"></span>
        </div>
        <div class="col-md-6">
            <label asp-for="ConfirmPassword" class="form-label"></label>
            <input asp-for="ConfirmPassword" class="form-control auth-input" placeholder="Re-enter password" />
            <span asp-validation-for="ConfirmPassword" class="auth-field-error"></span>
        </div>
    </div>
    <button type="submit" class="btn-glow w-100 justify-content-center mt-3"><i class="bi bi-person-plus"></i> Register</button>
</form>

<p class="text-center auth-muted small mt-3 mb-0">
    Already have an account? <a asp-action="Login" class="auth-link">Login here</a>
</p>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
