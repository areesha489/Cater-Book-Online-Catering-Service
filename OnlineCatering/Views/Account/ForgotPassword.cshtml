@model ForgotPasswordViewModel
@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "Forgot Password";
    ViewData["AuthTitle"] = "Reset Password";
    ViewData["AuthSubtitle"] = "Enter your details to set a new password";
}

<form asp-action="ForgotPassword" method="post" novalidate>
    <div asp-validation-summary="ModelOnly" class="auth-error-summary"></div>
    <div class="mb-3">
        <label asp-for="UserType" class="form-label"></label>
        <select asp-for="UserType" class="form-select auth-input">
            <option value="Customer">Customer</option>
            <option value="Caterer">Caterer</option>
        </select>
    </div>
    <div class="mb-3">
        <label asp-for="Username" class="form-label"></label>
        <input asp-for="Username" class="form-control auth-input" />
        <span asp-validation-for="Username" class="auth-field-error"></span>
    </div>
    <div class="mb-3">
        <label asp-for="NewPassword" class="form-label"></label>
        <input asp-for="NewPassword" class="form-control auth-input" />
        <span asp-validation-for="NewPassword" class="auth-field-error"></span>
    </div>
    <div class="mb-3">
        <label asp-for="ConfirmPassword" class="form-label"></label>
        <input asp-for="ConfirmPassword" class="form-control auth-input" />
        <span asp-validation-for="ConfirmPassword" class="auth-field-error"></span>
    </div>
    <button type="submit" class="btn-glow w-100 justify-content-center mb-2"><i class="bi bi-key"></i> Reset Password</button>
    <a asp-action="Login" class="btn-glass w-100 justify-content-center btn-sm"><i class="bi bi-arrow-left"></i> Back to Login</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
