<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CaterBook Admin</title>
    <link rel="icon" type="image/svg+xml" href="~/favicon.svg" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/logo.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
</head>
<body class="admin-body">
    <div class="admin-overlay" id="adminOverlay"></div>

    <aside class="admin-sidebar" id="adminSidebar">
        <div class="admin-brand">
            @{ ViewData["LogoSize"] = "sidebar"; ViewData["LogoVariant"] = "sidebar-v"; ViewData["LogoTagline"] = false; ViewData["LogoClass"] = ""; }
            <partial name="_CaterBookLogo" />
        </div>

        <nav class="admin-nav">
            @{
                var action = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
            }
            <div class="admin-nav-label">Main</div>
            <a asp-action="Dashboard" class="admin-nav-link @(action == "Dashboard" ? "active" : "")">
                <i class="bi bi-speedometer2"></i> Dashboard
            </a>
            <a asp-action="Customers" class="admin-nav-link @(action == "Customers" ? "active" : "")">
                <i class="bi bi-people-fill"></i> Customers
            </a>
            <a asp-action="Caterers" class="admin-nav-link @(action == "Caterers" ? "active" : "")">
                <i class="bi bi-shop"></i> Caterers
            </a>
            <a asp-action="AllBookings" class="admin-nav-link @(action is "AllBookings" or "BookingDetails" ? "active" : "")">
                <i class="bi bi-calendar-check-fill"></i> Bookings
            </a>

            <div class="admin-nav-label">Reports</div>
            <a asp-action="Payments" class="admin-nav-link @(action == "Payments" ? "active" : "")">
                <i class="bi bi-wallet2"></i> Payments
            </a>
            <a asp-action="AreasReport" class="admin-nav-link @(action == "AreasReport" ? "active" : "")">
                <i class="bi bi-geo-alt-fill"></i> Area Report
            </a>

            <div class="admin-nav-label">System</div>
            <a asp-action="Announcements" class="admin-nav-link @(action == "Announcements" ? "active" : "")">
                <i class="bi bi-megaphone-fill"></i> Announcements
            </a>
            <a asp-action="LoginUsers" class="admin-nav-link @(action == "LoginUsers" ? "active" : "")">
                <i class="bi bi-key-fill"></i> Login Users
            </a>
            <a asp-action="Modules" class="admin-nav-link @(action == "Modules" ? "active" : "")">
                <i class="bi bi-grid-1x2-fill"></i> Modules
            </a>

            <div class="admin-nav-label">Quick Links</div>
            <a asp-controller="Home" asp-action="Index" class="admin-nav-link">
                <i class="bi bi-house-door-fill"></i> Back to Website
            </a>
            <a asp-controller="Account" asp-action="Logout" class="admin-nav-link logout-link">
                <i class="bi bi-box-arrow-right"></i> Logout
            </a>
        </nav>

        <div class="admin-sidebar-footer">
            <div class="admin-sidebar-user">
                <i class="bi bi-person-circle"></i>
                <div>
                    <span>@(Context.Session.GetString("DisplayName") ?? "Administrator")</span>
                    <small>System Admin</small>
                </div>
            </div>
        </div>
    </aside>

    <div class="admin-main">
        <header class="admin-topbar">
            <button type="button" class="admin-topbar-toggle d-lg-none" id="sidebarToggle" aria-label="Toggle menu">
                <i class="bi bi-list fs-5"></i>
            </button>
            <div class="admin-topbar-info">
                <h1 class="admin-page-title">@ViewData["Title"]</h1>
                @if (ViewData["Subtitle"] != null)
                {
                    <p class="admin-page-subtitle">@ViewData["Subtitle"]</p>
                }
            </div>
            <div class="admin-topbar-actions">
                <span class="admin-topbar-date"><i class="bi bi-calendar3"></i> @DateTime.Now.ToString("dd MMM yyyy")</span>
                <div class="admin-user-badge">
                    <span class="avatar"><i class="bi bi-shield-check"></i></span>
                    <span>@(Context.Session.GetString("DisplayName") ?? "Admin")</span>
                </div>
            </div>
        </header>

        <main class="admin-content">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show">
                    <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @RenderBody()
        </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        const sidebar = document.getElementById('adminSidebar');
        const overlay = document.getElementById('adminOverlay');
        const toggle = document.getElementById('sidebarToggle');

        function openSidebar() {
            sidebar?.classList.add('show');
            overlay?.classList.add('show');
            document.body.style.overflow = 'hidden';
        }
        function closeSidebar() {
            sidebar?.classList.remove('show');
            overlay?.classList.remove('show');
            document.body.style.overflow = '';
        }

        toggle?.addEventListener('click', () => {
            sidebar?.classList.contains('show') ? closeSidebar() : openSidebar();
        });
        overlay?.addEventListener('click', closeSidebar);
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
