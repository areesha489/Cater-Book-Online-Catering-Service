<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CaterBook</title>
    <link rel="icon" type="image/svg+xml" href="~/favicon.svg" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/logo.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/theme-dark.css" asp-append-version="true" />
</head>
<body class="theme-dark">
    <nav class="navbar navbar-expand-lg navbar-dark navbar-main sticky-top">
        <div class="container">
            <a class="navbar-brand caterbook-logo-wrap" asp-controller="Home" asp-action="Index">
                @{ ViewData["LogoSize"] = "md"; ViewData["LogoVariant"] = "light"; ViewData["LogoTagline"] = false; }
                <partial name="_CaterBookLogo" />
            </a>
            <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="mainNav">
                <ul class="navbar-nav mx-auto gap-1">
                    <li class="nav-item"><a class="nav-link" data-nav="/home" asp-controller="Home" asp-action="Index">Home</a></li>
                    <li class="nav-item"><a class="nav-link" data-nav="/about" asp-controller="Home" asp-action="About">About</a></li>
                    <li class="nav-item"><a class="nav-link" data-nav="/home/services" asp-controller="Home" asp-action="Services">Services</a></li>
                    <li class="nav-item"><a class="nav-link" data-nav="/customer/restaurants" asp-controller="Customer" asp-action="Restaurants">All Restaurants</a></li>
                    <li class="nav-item"><a class="nav-link" data-nav="/customer/search" asp-controller="Customer" asp-action="Search">Search</a></li>
                    <li class="nav-item"><a class="nav-link" data-nav="/contact" asp-controller="Home" asp-action="Contact">Contact</a></li>
                    @if (Context.Session.GetString("UserType") == "Customer")
                    {
                        <li class="nav-item"><a class="nav-link" asp-controller="Customer" asp-action="Dashboard"><i class="bi bi-speedometer2 me-1"></i>My Panel</a></li>
                    }
                    @if (Context.Session.GetString("UserType") == "Caterer")
                    {
                        <li class="nav-item"><a class="nav-link" asp-controller="Caterer" asp-action="Dashboard"><i class="bi bi-speedometer2 me-1"></i>My Panel</a></li>
                    }
                    @if (Context.Session.GetString("UserType") == "Customer")
                    {
                        <li class="nav-item"><a class="nav-link" asp-controller="Customer" asp-action="MyBookings">My Bookings</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Customer" asp-action="Favorites">Favorites</a></li>
                    }
                    @if (Context.Session.GetString("UserType") == "Caterer")
                    {
                        <li class="nav-item"><a class="nav-link" asp-controller="Caterer" asp-action="Bookings">Bookings</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Caterer" asp-action="MenuCategories">Menu</a></li>
                    }
                    @if (Context.Session.GetString("UserType") == "Admin")
                    {
                        <li class="nav-item"><a class="nav-link" asp-controller="Admin" asp-action="Dashboard">Admin Panel</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Admin" asp-action="Customers">Customers</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Admin" asp-action="Caterers">Caterers</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Admin" asp-action="AllBookings">Bookings</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Admin" asp-action="Modules">Modules</a></li>
                    }
                </ul>
                <ul class="navbar-nav align-items-lg-center gap-2">
                    @if (Context.Session.GetInt32("UserId") != null)
                    {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle d-flex align-items-center gap-1" href="#" data-bs-toggle="dropdown">
                                <i class="bi bi-person-circle fs-5"></i>
                                <span class="d-none d-lg-inline">@Context.Session.GetString("DisplayName")</span>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end shadow border-0 rounded-3">
                                @if (Context.Session.GetString("UserType") == "Customer")
                                {
                                    <li><a class="dropdown-item" asp-controller="Customer" asp-action="Dashboard"><i class="bi bi-speedometer2 me-2"></i>Dashboard</a></li>
                                    <li><a class="dropdown-item" asp-controller="Customer" asp-action="Profile"><i class="bi bi-person me-2"></i>My Profile</a></li>
                                    <li><a class="dropdown-item" asp-controller="Customer" asp-action="Messages"><i class="bi bi-chat-dots me-2"></i>Messages</a></li>
                                }
                                else if (Context.Session.GetString("UserType") == "Admin")
                                {
                                    <li><a class="dropdown-item" asp-controller="Admin" asp-action="Dashboard"><i class="bi bi-shield me-2"></i>Admin Dashboard</a></li>
                                    <li><a class="dropdown-item" asp-controller="Admin" asp-action="LoginUsers"><i class="bi bi-people me-2"></i>Login Users</a></li>
                                }
                                else
                                {
                                    <li><a class="dropdown-item" asp-controller="Caterer" asp-action="Dashboard"><i class="bi bi-speedometer2 me-2"></i>Dashboard</a></li>
                                    <li><a class="dropdown-item" asp-controller="Caterer" asp-action="Profile"><i class="bi bi-person me-2"></i>Profile</a></li>
                                    <li><a class="dropdown-item" asp-controller="Caterer" asp-action="Invoices"><i class="bi bi-receipt me-2"></i>Invoices</a></li>
                                }
                                <li><hr class="dropdown-divider" /></li>
                                <li><a class="dropdown-item text-danger" asp-controller="Account" asp-action="Logout"><i class="bi bi-box-arrow-right me-2"></i>Logout</a></li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item"><a class="nav-link btn-nav-login" asp-controller="Account" asp-action="Login">Login</a></li>
                        <li class="nav-item dropdown">
                            <a class="nav-link btn-nav-register dropdown-toggle" href="#" data-bs-toggle="dropdown">Register</a>
                            <ul class="dropdown-menu dropdown-menu-end shadow border-0 rounded-3">
                                <li><a class="dropdown-item" asp-controller="Account" asp-action="RegisterCustomer"><i class="bi bi-person me-2"></i>As Customer</a></li>
                                <li><a class="dropdown-item" asp-controller="Account" asp-action="RegisterCaterer"><i class="bi bi-shop me-2"></i>As Caterer</a></li>
                            </ul>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <main>
        @if (TempData["Success"] != null)
        {
            <div class="container mt-3">
                <div class="alert alert-success alert-dismissible fade show rounded-3 shadow-sm border-0" role="alert">
                    <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="container mt-3">
                <div class="alert alert-danger alert-dismissible fade show rounded-3 shadow-sm border-0" role="alert">
                    <i class="bi bi-exclamation-circle me-2"></i>@TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            </div>
        }
        @RenderBody()
    </main>

    <footer class="footer-main">
        <div class="container">
            <div class="row g-4">
                <div class="col-lg-4 col-md-6">
                    <div class="footer-brand">
                        @{ ViewData["LogoSize"] = "footer"; ViewData["LogoVariant"] = "light"; ViewData["LogoTagline"] = false; }
                        <partial name="_CaterBookLogo" />
                    </div>
                    <p class="footer-tagline">Book Catering, Simplified</p>
                    <p class="footer-desc">Pakistan's trusted platform to discover, compare, and book professional caterers for weddings, corporate events, birthdays, and more.</p>
                    <div class="social-links">
                        <a href="#" class="social-link"><i class="bi bi-facebook"></i></a>
                        <a href="#" class="social-link"><i class="bi bi-instagram"></i></a>
                        <a href="#" class="social-link"><i class="bi bi-whatsapp"></i></a>
                        <a href="#" class="social-link"><i class="bi bi-envelope"></i></a>
                    </div>
                </div>
                <div class="col-lg-2 col-md-6">
                    <h6 class="footer-heading">Quick Links</h6>
                    <ul class="footer-links">
                        <li><a asp-controller="Home" asp-action="Index">Home</a></li>
                        <li><a asp-controller="Home" asp-action="About">About Us</a></li>
                        <li><a asp-controller="Home" asp-action="Services">Our Services</a></li>
                        <li><a asp-controller="Customer" asp-action="Restaurants">All Restaurants</a></li>
                        <li><a asp-controller="Customer" asp-action="Search">Search Caterers</a></li>
                        <li><a asp-controller="Home" asp-action="Modules">System Modules</a></li>
                        <li><a asp-controller="Home" asp-action="Contact">Contact</a></li>
                    </ul>
                </div>
                <div class="col-lg-2 col-md-6">
                    <h6 class="footer-heading">For Users</h6>
                    <ul class="footer-links">
                        <li><a asp-controller="Account" asp-action="RegisterCustomer">Register as Customer</a></li>
                        <li><a asp-controller="Account" asp-action="RegisterCaterer">Register as Caterer</a></li>
                        <li><a asp-controller="Account" asp-action="Login">Login</a></li>
                    </ul>
                </div>
                <div class="col-lg-4 col-md-6">
                    <h6 class="footer-heading">Contact Info</h6>
                    <ul class="footer-links">
                        <li><i class="bi bi-geo-alt me-2 text-warning"></i>Lahore, Karachi, Islamabad</li>
                        <li><i class="bi bi-telephone me-2 text-warning"></i>+92 300 1234567</li>
                        <li><i class="bi bi-envelope me-2 text-warning"></i>support@caterbook.com</li>
                    </ul>
                    <div class="mt-3 p-3 rounded-3" style="background:rgba(255,255,255,0.05)">
                        <small class="d-block mb-1"><i class="bi bi-info-circle me-1"></i> Booking Rules</small>
                        <small class="opacity-75">Min. 7 days advance • Min. 50 guests • Cancellation charges vary</small>
                    </div>
                </div>
            </div>
            <div class="footer-bottom text-center">
                &copy; @DateTime.Now.Year CaterBook. All rights reserved.
            </div>
        </div>
    </footer>

    <button class="back-to-top" aria-label="Back to top"><i class="bi bi-arrow-up"></i></button>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
