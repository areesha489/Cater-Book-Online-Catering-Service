@{
    var size = ViewData["LogoSize"]?.ToString() ?? "md";
    var variant = ViewData["LogoVariant"]?.ToString() ?? "light";
    var showTagline = ViewData["LogoTagline"] as bool? ?? false;
    var cssClass = ViewData["LogoClass"]?.ToString() ?? "";
}

<span class="caterbook-logo caterbook-logo--@size caterbook-logo--@variant @cssClass" role="img" aria-label="CaterBook">
    <span class="caterbook-mark" aria-hidden="true">
        <svg class="caterbook-mark-svg" viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
            <defs>
                <linearGradient id="cb-grad-@size" x1="0%" y1="0%" x2="100%" y2="100%">
                    <stop offset="0%" stop-color="#f39c12"/>
                    <stop offset="50%" stop-color="#f4a261"/>
                    <stop offset="100%" stop-color="#e67e22"/>
                </linearGradient>
                <linearGradient id="cb-bg-@size" x1="0%" y1="0%" x2="100%" y2="100%">
                    <stop offset="0%" stop-color="#1a1a2e"/>
                    <stop offset="100%" stop-color="#0d0d12"/>
                </linearGradient>
            </defs>
            <rect width="64" height="64" rx="16" fill="url(#cb-bg-@size)"/>
            <rect x="1" y="1" width="62" height="62" rx="15" stroke="url(#cb-grad-@size)" stroke-width="1.5" fill="none" opacity="0.6"/>
            <path d="M18 38h28v10a4 4 0 0 1-4 4H22a4 4 0 0 1-4-4V38z" fill="url(#cb-grad-@size)"/>
            <path d="M16 38h32v3H16z" fill="#fff" opacity=".92"/>
            <path d="M32 14c-8 0-12 6-12 11v6h24v-6c0-5-4-11-12-11z" fill="url(#cb-grad-@size)"/>
            <ellipse cx="32" cy="14" rx="10" ry="3" fill="#ffd89b" opacity=".9"/>
            <circle cx="48" cy="18" r="3" fill="#f39c12" opacity=".85"/>
        </svg>
    </span>
    <span class="caterbook-wordmark">
        <span class="caterbook-cater">Cater</span><span class="caterbook-book">Book</span>
    </span>
    @if (showTagline)
    {
        <span class="caterbook-tagline-sep" aria-hidden="true"></span>
        <span class="caterbook-tagline-inline">Book Catering, Simplified</span>
    }
</span>
