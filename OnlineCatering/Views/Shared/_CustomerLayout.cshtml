<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CaterBook</title>
    <link rel="icon" type="image/svg+xml" href="~/favicon.svg" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/logo.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/panel.css" asp-append-version="true" />
</head>
<body class="panel-body theme-customer">
    <div class="panel-overlay" id="panelOverlay"></div>

    <aside class="panel-sidebar" id="panelSidebar">
        <div class="panel-brand">
            @{ ViewData["LogoSize"] = "sidebar"; ViewData["LogoVariant"] = "sidebar-v"; ViewData["LogoTagline"] = false; }
            <partial name="_CaterBookLogo" />
        </div>
        <nav class="panel-nav">
            @{
                var action = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
            }
            <div class="panel-nav-label">Main</div>
            <a asp-action="Dashboard" class="panel-nav-link @(action == "Dashboard" ? "active" : "")"><i class="bi bi-speedometer2"></i> Dashboard</a>
            <a asp-action="MyBookings" class="panel-nav-link @(action is "MyBookings" or "BookingDetails" ? "active" : "")"><i class="bi bi-calendar-check"></i> My Bookings</a>
            <a asp-action="Favorites" class="panel-nav-link @(action == "Favorites" ? "active" : "")"><i class="bi bi-heart-fill"></i> Favorites</a>
            <a asp-action="Profile" class="panel-nav-link @(action == "Profile" ? "active" : "")"><i class="bi bi-person-gear"></i> My Profile</a>

            <div class="panel-nav-label">Browse & Book</div>
            <a asp-action="Restaurants" class="panel-nav-link"><i class="bi bi-shop"></i> All Restaurants</a>
            <a asp-action="Search" class="panel-nav-link"><i class="bi bi-search"></i> Search Caterers</a>

            <div class="panel-nav-label">Communication</div>
            <a asp-action="Messages" class="panel-nav-link @(action is "Messages" or "MessageDetails" or "SendMessage" or "ReplyMessage" ? "active" : "")"><i class="bi bi-chat-dots-fill"></i> Messages</a>

            <div class="panel-nav-label">Account</div>
            <a asp-controller="Home" asp-action="Index" class="panel-nav-link"><i class="bi bi-house"></i> Back to Website</a>
            <a asp-controller="Account" asp-action="Logout" class="panel-nav-link logout-link"><i class="bi bi-box-arrow-right"></i> Logout</a>
        </nav>
        <div class="panel-sidebar-footer">
            <div class="panel-sidebar-user">
                <i class="bi bi-person-circle"></i>
                <div>
                    <span>@(Context.Session.GetString("DisplayName") ?? "Customer")</span>
                    <small>Customer Account</small>
                </div>
            </div>
        </div>
    </aside>

    <div class="panel-main">
        <header class="panel-topbar">
            <button type="button" class="panel-topbar-toggle d-lg-none" id="panelToggle"><i class="bi bi-list fs-5"></i></button>
            <div class="panel-topbar-info">
                <h1 class="panel-page-title">@ViewData["Title"]</h1>
                @if (ViewData["Subtitle"] != null) { <p class="panel-page-subtitle">@ViewData["Subtitle"]</p> }
            </div>
            <div class="panel-topbar-actions">
                <a asp-action="Restaurants" class="panel-btn panel-btn-accent d-none d-md-inline-flex"><i class="bi bi-plus-lg"></i> Book Catering</a>
                <div class="panel-user-badge">
                    <span class="avatar"><i class="bi bi-person-fill"></i></span>
                    <span>@(Context.Session.GetString("DisplayName") ?? "Customer")</span>
                </div>
            </div>
        </header>
        <main class="panel-content">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show"><i class="bi bi-check-circle me-2"></i>@TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show"><i class="bi bi-exclamation-triangle me-2"></i>@TempData["Error"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
            }
            @RenderBody()
        </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        const sidebar = document.getElementById('panelSidebar');
        const overlay = document.getElementById('panelOverlay');
        document.getElementById('panelToggle')?.addEventListener('click', () => {
            const open = sidebar?.classList.toggle('show');
            overlay?.classList.toggle('show', open);
            document.body.style.overflow = open ? 'hidden' : '';
        });
        overlay?.addEventListener('click', () => {
            sidebar?.classList.remove('show');
            overlay?.classList.remove('show');
            document.body.style.overflow = '';
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
